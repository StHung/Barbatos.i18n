<Page x:Class="Barbatos.i18n.Sample.Wpf.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:i18n="http://schemas.barbatos.co/i18n/2026/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="600"
      Title="HomePage">

    <Page.Resources>
        <i18n:LocalizeConverter x:Key="LocalizeConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
        <StackPanel Margin="20" HorizontalAlignment="Stretch" MaxWidth="600" VerticalAlignment="Top">
            <TextBlock Text="{i18n:StringLocalizer Text='Title'}" FontWeight="Bold" FontSize="22" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <Button Command="{Binding ShowMessageCommand}" Content="Show Localized MessageBox" Width="250" Padding="10" Margin="0,0,0,30" HorizontalAlignment="Center" Cursor="Hand" Background="#0078D7" Foreground="White" FontWeight="Bold" BorderThickness="0" />

            <!-- Switch Language -->
            <Border BorderBrush="#DDDDDD" BorderThickness="1" Padding="15" Margin="0,0,0,20" CornerRadius="5" Background="#F9F9F9">
                <StackPanel>
                    <TextBlock Text="{i18n:StringLocalizer Text='SwitchLanguage'}" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding SupportedCultures}" SelectedItem="{Binding SelectedCulture}" DisplayMemberPath="NativeName" Width="250" HorizontalAlignment="Center" Padding="5" Cursor="Hand" SelectionChanged="LanguageComboBox_SelectionChanged" />
                </StackPanel>
            </Border>

            <!-- Basic Static Arguments -->
            <TextBlock Text="{i18n:StringLocalizer Text='HeaderBasicStatic'}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            <TextBlock Text="{i18n:StringLocalizer Text='Greeting'}" Margin="10,0,0,5" Foreground="#005A9E"/>
            <TextBlock Text="{i18n:StringLocalizer Text='GreetingWithName', Arg='Static John'}" Margin="10,0,0,5" Foreground="#005A9E"/>
            <TextBlock Text="{i18n:PluralStringLocalizer Text='OneApple', PluralText='ManyApples', Count=5}" Margin="10,0,0,25" Foreground="#005A9E" />

            <!-- Dynamic String (Binding 1 Arg) -->
            <TextBlock Text="{i18n:StringLocalizer Text='HeaderDynamicSingle'}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="10,0,0,10">
                <TextBlock Text="{i18n:StringLocalizer Text='EnterName'}" VerticalAlignment="Center" Width="100"/>
                <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Width="200" Padding="5" />
            </StackPanel>
            <TextBlock Text="{i18n:StringLocalizer Text='GreetingWithName', BindArg={Binding UserName, StringFormat='\{0\} |˶˙ᵕ˙ )ﾉﾞ'}}" Margin="10,0,0,25" Foreground="#107C10"/>

            <!-- Dynamic String (Binding Multiple Args) -->
            <TextBlock Text="{i18n:StringLocalizer Text='HeaderDynamicMultiple'}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="10,0,0,10">
                <TextBlock Text="{i18n:StringLocalizer Text='FirstName'}" VerticalAlignment="Center" Width="80"/>
                <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="5" Margin="0,0,15,0"/>
                <TextBlock Text="{i18n:StringLocalizer Text='LastName'}" VerticalAlignment="Center" Width="70"/>
                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="5" />
            </StackPanel>
            <TextBlock Text="{i18n:StringLocalizer Text='GreetingWithFullName', BindArg={Binding FirstName}, BindArg2={Binding LastName}}" Margin="10,0,0,25" Foreground="#D83B01"/>

            <!-- Plural String (Binding) -->
            <TextBlock Text="{i18n:StringLocalizer Text='HeaderPlural'}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="10,0,0,10">
                <Button Content=" - " Command="{Binding DecrementApplesCommand}" Width="40" Padding="5" FontWeight="Bold" Cursor="Hand"/>
                <TextBlock Text="{Binding AppleCount}" Margin="15,0,15,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="16" MinWidth="20" TextAlignment="Center"/>
                <Button Content=" + " Command="{Binding IncrementApplesCommand}" Width="40" Padding="5" FontWeight="Bold" Cursor="Hand"/>
            </StackPanel>
            <TextBlock Text="{i18n:PluralStringLocalizer Text='OneApple', PluralText='ManyApples', BindCount={Binding AppleCount}}" Margin="10,0,0,25" Foreground="#A80000" />

            <!-- ComboBox and ToolTip -->
            <TextBlock Text="{i18n:StringLocalizer Text='HeaderAttributes'}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="10,0,0,25">
                <ComboBox ItemsSource="{Binding AvailableOptions}" SelectedIndex="0" Width="200" Margin="0,0,25,0" Padding="5" Cursor="Hand">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource LocalizeConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Content="{i18n:StringLocalizer Text='HoverMe'}" ToolTip="{i18n:StringLocalizer Text='ButtonTooltip'}" Padding="20,5" Cursor="Hand"/>
            </StackPanel>

            <!-- String Format -->
            <TextBlock Text="{i18n:StringLocalizer Text='HeaderStringFormat'}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            <TextBlock Text="{i18n:StringLocalizer Text='Greeting', StringFormat='==&gt; {0} &lt;=='}" Margin="10,0,0,5" Foreground="#6B69D6"/>
            <TextBlock Text="{i18n:StringLocalizer Text='GreetingWithName', BindArg={Binding UserName}, StringFormat='[ {0} ]'}" Margin="10,0,0,25" Foreground="#6B69D6"/>

            <!-- Namespaces (LocalizationSet Name) -->
            <TextBlock Text="{i18n:StringLocalizer Text='HeaderNamespace'}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            <TextBlock Text="{i18n:StringLocalizer Text='NetworkError', Namespace='errors'}" Margin="10,0,0,25" Foreground="#D13438"/>

            <!-- Multiple Providers (ProviderKey) -->
            <TextBlock Text="{i18n:StringLocalizer Text='HeaderProviderKey'}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            <TextBlock Text="{i18n:StringLocalizer Text='BonusMessage', ProviderKey='SecondaryProvider', Namespace='extra'}" Margin="10,0,0,25" Foreground="#FF8C00"/>
            <!-- Culture format -->
            <TextBlock Text="{i18n:StringLocalizer Text='HeaderCultureFormat'}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            <TextBlock Text="{i18n:StringLocalizer Text='CurrentDateIs', BindArg={Binding CurrentDate}}" Margin="10,0,0,5" Foreground="#005A9E"/>
            <TextBlock Text="{i18n:StringLocalizer Text='LongDateIs', BindArg={Binding CurrentDate}}" Margin="10,0,0,5" Foreground="#005A9E"/>
            <TextBlock Text="{i18n:StringLocalizer Text='FullDateTimeIs', BindArg={Binding CurrentDate}}" Margin="10,0,0,5" Foreground="#005A9E"/>
            <TextBlock Text="{i18n:StringLocalizer Text='PriceIs', BindArg={Binding Price}}" Margin="10,0,0,5" Foreground="#107C10"/>
            <TextBlock Text="{i18n:StringLocalizer Text='DistanceIs', BindArg={Binding Distance}}" Margin="10,0,0,25" Foreground="#107C10"/>
        </StackPanel>
    </ScrollViewer>
</Page>
